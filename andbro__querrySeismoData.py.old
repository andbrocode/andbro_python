#!/usr/bin/python
#
# querry seismic traces and station data
#

def __querrySeismoData(seed_id=None, beg=None, end=None, restitute=True, details=None):

    '''
    querry seismic traces and station data
    
    Dependencies: 
        from obspy.clients.fdsn import Client, RoutingClient
        from obspy.core.util import AttribDict
    example:
    	>>> fur, fur_inv = __querrySeismoData("GR.FUR..BH*", tbeg, tend, restitute=True, details=None))
    ''' 
    
    from obspy.clients.fdsn import Client, RoutingClient
    from obspy.core.util import AttribDict
    from obspy import UTCDateTime
    
    ## split seed_id string 
    net, sta, loc, cha = seed_id.split(".")
    
    beg = UTCDateTime(beg)
    end = UTCDateTime(end)
    
    ## check if input variables are as expected
    for arg in [net, sta, loc, cha, beg, end]:
        if arg is None and not 'loc':
            raise NameError(print(f"\nwell, {arg} has not been defined after all!"))
            exit()
            
    ## state which data is requested       
    if details:
        if loc != None:
            print(f'\nGet data:  {net}.{sta}.{loc}.{cha} ({float(end-beg)/60}) ...')
        else: 
            print(f'\nGet data:  {net}.{sta}..{cha} (traces of {float(end-beg)/60} min duration) ...')

    ## attempting to get data from either EIDA or IRIS.
    try: 
        route = RoutingClient("eida-routing")
        if details:
            print("\nUsing Eida-Routing...")
        if route:
            inv = route.get_stations(network=net, station=sta, location=loc, channel=cha,
                                     starttime=beg, endtime=end, level="response")
            if details:
                print(f"\nRequesting from {len(inv.get_contents()['networks'])} network(s) and {len(inv.get_contents()['stations'])} station(s)")

            st = route.get_waveforms(network=net, station=sta, location=loc, channel=cha, 
                                     starttime=beg, endtime=end)
            try:
                st[0].stats.coordinates = AttribDict({  'latitude':  inv[0][0].latitude,
                                                        'elevation': inv[0][0].elevation,
                                                        'longitude': inv[0][0].longitude,
                                                      })
            except:
                if details:
                	print(f"no coordinates added to {station[0]}")

    except: 
        route = RoutingClient("iris-federator")
        if details:
            print("\nUsing Iris-Federator...")
        if route:
            inv = route.get_stations(network=net, station=sta, location=loc, channel=cha,
                                     starttime=beg, endtime=end, level="response")
            if details:
                print(f"\nRequesting from {len(inv.get_contents()['networks'])} network(s) and {len(inv.get_contents()['stations'])} stations(s)")
        
            st = route.get_waveforms(network=net, station=sta, location=loc, channel=cha, 
                                     starttime=beg, endtime=end)
    
    ## remove response of instrument specified in inventory
    if restitute:
               
#        pre_filt = [0.001, 0.005, 45, 50]
        pre_filter = (0.01, 0.05, 20, 40)

        out="VEL"  # "DISP" "ACC"
        
        st.remove_response(
            inventory=inv, 
            pre_filt=pre_filter,
            output=out,
        )
        
        if details:
            if pre_filter:
                print(f'\npre-filter is applied: {pre_filter}')

            print(f"\nremoving response ...")
            print(f"\noutput {out}")
    
    if details:
        print('\nFinished\n_______________\n')
    
    return st, inv
    
## End of File
